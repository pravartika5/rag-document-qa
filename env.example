# ──────────────────────────────────────────────
# RAG Document Q&A — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Required: Your OpenAI API key
OPENAI_API_KEY=sk-...

# LLM model (gpt-4o-mini is fast & cheap; use gpt-4o for higher quality)
LLM_MODEL=gpt-4o-mini

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB persistence directory (relative to /backend)
CHROMA_PERSIST_DIR=./chroma_db

# Text chunking settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150
